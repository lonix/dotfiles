# Global Config
[user]
  name = Stian Buch Larsen
  email = lonixx@gmail.com
  signingkey = 55CF05DD043E4F6C

[include]
    path = .gitconfig.local


[branch "master"]
    remote = origin
    merge = refs/heads/master

[push]
    default = simple
    followTags = true

[url "git@github.com:"]
    insteadof = github:

[fetch]
  prune = true
[commit]
  gpgSign = true
[pull]
  rebase = true
[init]
  defaultBranch = main

[color]
  branch = always
  diff = always
  status = auto

[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green

[color "diff"]
  meta = yellow
  frag = magenta
  old = red
  new = green

[color "status"]
  added = yellow
  changed = green
  untracked = cyan
