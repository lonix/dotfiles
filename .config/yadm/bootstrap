#!/bin/bash

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log()  { echo -e "${GREEN}[bootstrap]${NC} $1"; }
warn() { echo -e "${YELLOW}[bootstrap]${NC} $1"; }
err()  { echo -e "${RED}[bootstrap]${NC} $1" >&2; }

ci_mode() { [ -n "${CI:-}" ]; }

# Detect OS by package manager / OSTYPE
detect_os() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
    elif command -v dnf >/dev/null 2>&1; then
        echo "rhel"
    elif command -v apt-get >/dev/null 2>&1; then
        echo "debian"
    else
        err "Unsupported OS — no supported package manager found."
        exit 1
    fi
}

OS=$(detect_os)
log "Detected OS: $OS"
ci_mode && warn "CI environment detected — skipping interactive steps."

# Ensure ~/.bin exists and is in PATH for this session
mkdir -p "$HOME/.bin"
export PATH="$HOME/.bin:$PATH"

# ── macOS ────────────────────────────────────────────────────────────────────
if [[ "$OS" == "macos" ]]; then
    if ! command -v brew >/dev/null 2>&1; then
        log "Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi

    if [ -f "$HOME/.Brewfile" ]; then
        log "Installing Homebrew packages..."
        brew bundle --global
    fi

# ── AlmaLinux / RHEL / Fedora ────────────────────────────────────────────────
elif [[ "$OS" == "rhel" ]]; then
    log "Installing base packages via dnf..."
    sudo dnf install -y epel-release
    sudo dnf install -y git curl wget fish

# ── Ubuntu / Debian ──────────────────────────────────────────────────────────
elif [[ "$OS" == "debian" ]]; then
    log "Installing base packages via apt..."
    sudo apt-get update
    sudo apt-get install -y git curl wget yadm

    if ! command -v fish >/dev/null 2>&1; then
        log "Installing fish shell..."
        sudo apt-add-repository -y ppa:fish-shell/release-4
        sudo apt-get update
        sudo apt-get install -y fish
    fi
fi

# ── All platforms: Starship ───────────────────────────────────────────────────
if ! command -v starship >/dev/null 2>&1; then
    log "Installing Starship..."
    curl -fsSL https://starship.rs/install.sh | sh -s -- -y
fi

# ── All platforms: yadm (binary fallback if not installed by package manager) ─
if ! command -v yadm >/dev/null 2>&1; then
    log "Installing yadm via binary fallback..."
    curl -fLo "$HOME/.bin/yadm" \
        https://github.com/TheLocehiliosan/yadm/raw/master/yadm
    chmod +x "$HOME/.bin/yadm"
fi

# ── All platforms: shell + yadm remote ───────────────────────────────────────
if ! ci_mode; then
    FISH_PATH=$(command -v fish)

    if ! grep -qF "$FISH_PATH" /etc/shells; then
        log "Adding fish to /etc/shells..."
        echo "$FISH_PATH" | sudo tee -a /etc/shells
    fi

    if [ "$SHELL" != "$FISH_PATH" ]; then
        log "Setting fish as default shell..."
        chsh -s "$FISH_PATH"
    fi

    if ! yadm remote get-url origin 2>/dev/null | grep -q "git@github"; then
        log "Setting yadm remote to SSH..."
        yadm remote set-url origin "git@github.com:lonix/dotfiles.git"
    fi
fi

# ── macOS only: iTerm2 + system defaults ─────────────────────────────────────
if [[ "$OS" == "macos" ]] && ! ci_mode; then
    if [ -d "$HOME/.iterm2" ]; then
        log "Setting iTerm2 preference folder..."
        defaults write com.googlecode.iterm2 PrefsCustomFolder "$HOME/.iterm2"
        defaults write com.googlecode.iterm2 LoadPrefsFromCustomFolder -bool true
    fi

    log "Configuring macOS defaults..."

    # Save / print panels
    defaults write NSGlobalDomain NSNavPanelExpandedStateForSaveMode -bool true
    defaults write NSGlobalDomain PMPrintingExpandedStateForPrint -bool true

    # UI / input
    defaults write NSGlobalDomain NSAutomaticWindowAnimationsEnabled -bool false
    defaults write NSGlobalDomain AppleKeyboardUIMode -int 3
    defaults write NSGlobalDomain NSAutomaticSpellingCorrectionEnabled -bool false

    # Screensaver / security
    defaults write com.apple.screensaver askForPassword -int 1
    defaults write com.apple.screensaver askForPasswordDelay -int 0

    # Finder
    defaults write com.apple.finder ShowStatusBar -bool true
    defaults write com.apple.finder _FXShowPosixPathInTitle -bool true
    defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false
    defaults write com.apple.finder WarnOnEmptyTrash -bool false
    defaults write com.apple.desktopservices DSDontWriteNetworkStores -bool true

    # Dock
    defaults write com.apple.dock show-process-indicators -bool true
    defaults write com.apple.dock expose-animation-duration -int 0
    defaults write com.apple.dock static-only -bool true
    defaults write com.apple.dock autohide -bool true
    defaults write com.apple.dock showhidden -bool true
    defaults write com.apple.dock tilesize -int 25
    defaults write com.apple.dock mineffect -string "suck"

    # Misc
    defaults write com.apple.mail AddressesIncludeNameOnPasteboard -bool false
    defaults write com.apple.TimeMachine DoNotOfferNewDisksForBackup -bool true

    killall Dock
    killall Finder
fi

log "Bootstrap complete!"
